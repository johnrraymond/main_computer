#!/bin/sh
set -eu

SECRETS_FILE="local.secrets"

if [ ! -f "$SECRETS_FILE" ]; then
  echo "No local.secrets file found; skipping local secret scan."
  exit 0
fi

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$staged_files" ]; then
  exit 0
fi

while IFS= read -r secret || [ -n "$secret" ]; do
  secret="$(printf '%s' "$secret" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"

  case "$secret" in
    ""|\#*) continue ;;
  esac

  printf '%s\n' "$staged_files" | while IFS= read -r file || [ -n "$file" ]; do
    [ -n "$file" ] || continue

    if git show ":$file" 2>/dev/null | grep -F -- "$secret" >/dev/null; then
      echo "BLOCKED: staged file contains a protected secret."
      echo "File: $file"
      echo "Secret source: $SECRETS_FILE"
      exit 1
    fi
  done
done < "$SECRETS_FILE"

exit 0