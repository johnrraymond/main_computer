# Main Computer repository line-ending policy
#
# Goal:
# - Keep normal text files normalized by Git.
# - Force anything executed by Linux, WSL, Docker, or bash to LF.
# - Keep Windows-native command scripts CRLF.
# - Protect binary assets from line-ending conversion.

###############################################################################
# Default text handling
###############################################################################

* text=auto

###############################################################################
# Linux / WSL / Docker / shell-executed files must be LF
###############################################################################

*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.ksh text eol=lf
*.fish text eol=lf

# Extensionless or named Linux entrypoints
docker/executor/main-computer-exec text eol=lf
docker/**/entrypoint text eol=lf
docker/**/entrypoint-* text eol=lf
docker/**/main-computer-* text eol=lf
docker/**/run text eol=lf
docker/**/run-* text eol=lf
docker/**/start text eol=lf
docker/**/start-* text eol=lf
docker/**/stop text eol=lf
docker/**/stop-* text eol=lf

# Tooling scripts that may be executed through WSL/bash
tools/**/*.sh text eol=lf
scripts/**/*.sh text eol=lf
bin/**/*.sh text eol=lf

###############################################################################
# Docker / container configuration should be LF
###############################################################################

Dockerfile text eol=lf
Dockerfile.* text eol=lf
**/Dockerfile text eol=lf
**/Dockerfile.* text eol=lf

docker-compose*.yml text eol=lf
docker-compose*.yaml text eol=lf
compose*.yml text eol=lf
compose*.yaml text eol=lf

*.env text eol=lf
*.env.example text eol=lf
.env text eol=lf
.env.* text eol=lf

###############################################################################
# Python / web / config text files
###############################################################################

*.py text eol=lf
*.pyi text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.xml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.service text eol=lf

###############################################################################
# Windows-native scripts may use CRLF
###############################################################################

*.bat text eol=crlf
*.cmd text eol=crlf

# PowerShell works with LF, but CRLF is conventional on Windows.
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

###############################################################################
# Binary files: never modify line endings
###############################################################################

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.bmp binary
*.tif binary
*.tiff binary
*.svg text eol=lf

*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
*.tar binary
*.7z binary
*.rar binary

*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.bin binary

*.db binary
*.sqlite binary
*.sqlite3 binary

*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

*.mp3 binary
*.wav binary
*.ogg binary
*.mp4 binary
*.mov binary
*.avi binary
*.webm binary