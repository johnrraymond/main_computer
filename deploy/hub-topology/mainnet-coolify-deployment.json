{
  "kind": "main_computer.coolify_hub_cluster_placement.v1",
  "network_key": "mainnet",
  "topology_path": "deploy/hub-topology/mainnet-topology.json",
  "coolify": {
    "server_url_source": "command-line",
    "server_url_argument": "--set-coolify-url",
    "server_url_argument_format": "<server-name>:<coolify-base-url>",
    "server_token_source": "environment-or-command-line"
  },
  "servers": [
    {
      "name": "mainnet-a",
      "vpn_ip": "10.0.0.10"
    }
  ],
  "foundationdb": {
    "image": "foundationdb/foundationdb:7.4.6",
    "cluster_description": "main_computer_mainnet",
    "cluster_id": "replace-with-mainnet-fdb-cluster-id",
    "cluster_file_path": "/data/main-computer/hub/mainnet-exp-fdb/fdb.cluster",
    "namespace": "main-computer-mainnet-exp-fdb-stable-live-sessions",
    "configure": "single ssd",
    "network": {
      "transport": "private-vpn-or-host-local",
      "bind_address_source": "servers[].vpn_ip",
      "publish_public_ports": false
    },
    "instances": [
      {
        "id": "mainnet-fdb1",
        "coolify_server": "mainnet-a",
        "port": 4550,
        "machine_id": "mainnet-a",
        "zone_id": "mainnet-a"
      }
    ]
  },
  "hubs": [
    {
      "hub_id": "mainnet-hub1",
      "coolify_server": "mainnet-a",
      "public_url": "https://mainnet-hub1.greatlibrary.io",
      "runtime_dir": "/data/main-computer/hub/mainnet-exp-fdb",
      "cluster_file_path": "/data/main-computer/hub/mainnet-exp-fdb/fdb.cluster",
      "namespace": "main-computer-mainnet-exp-fdb-stable-live-sessions"
    }
  ],
  "public_entry_urls": [
    "https://mainnet-hub.greatlibrary.io"
  ],
  "operator_notes": [
    "Mainnet deployment requires explicit operator binding for the Coolify API URL and token; never commit tokens or live private IPs here.",
    "Replace servers[].vpn_ip with the mainnet host's private VPN address before using this placement file.",
    "The FoundationDB port must stay private. Do not publish FDB through Traefik or public DNS.",
    "Apply the chain plan first, deploy contracts to runtime/deployments/mainnet/latest.json, then deploy the Hub with the same mainnet chain profile."
  ]
}
