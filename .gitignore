# Selected runtime websites are intentionally source-controlled.
# Keep the website exceptions near the end so they override broad generated-file
# rules such as runtime/*, *.sqlite, media globs, and manifest.json. Narrow
# local-only ignores may follow these exceptions.
!runtime/
runtime/*
!runtime/websites/
runtime/websites/*
!runtime/websites/hub-site/
!runtime/websites/hub-site/**
!runtime/websites/johnrraymond/
!runtime/websites/johnrraymond/**


# Disposable static route/publish probe pages under versioned runtime sites.
# These are local diagnostics and should not be committed.
runtime/websites/*/__*probe*/
runtime/websites/*/__*probe*/**

# Per-site SSH publish passwords must stay local, even for versioned runtime sites.
runtime/websites/*/ssh_password.local

# Generated local-platform Docker Compose outputs are local runtime artifacts.
# Website source/config stays tracked; only generated Docker files are ignored.
deploy/local-platform/generated/
runtime/websites/*/.main-computer/local-platform/docker-compose.yml

# Don't need these smoke outputs in git.
supercut_smoke_output/

# Don't need the hub lab output.
deploy/scheduler-lab/output

# Local Hub topology fixtures are part of dev/test/smoke mode.
!deploy/hub-topology/
!deploy/hub-topology/*.json
